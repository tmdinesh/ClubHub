# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ccops:ccops_pass@postgres:5432/ccops
TEST_DATABASE_URL=postgresql+asyncpg://ccops:ccops_pass@postgres:5432/ccops_test

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://ccops:ccops_pass@rabbitmq:5672/

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost/api/auth/google/callback

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Domain Whitelist (comma-separated) ────────────────────────────────────────
ALLOWED_EMAIL_DOMAINS=college.edu,university.ac.in

# ── Super Admin ───────────────────────────────────────────────────────────────
# Store a bcrypt hash, never the plaintext password.
# Generate with: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt(12)).decode())"
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=$2b$12$...bcrypt-hash-here...

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Gmail: enable 2FA on the account, then generate an App Password at
#   myaccount.google.com/apppasswords — paste the 16-char code as SMTP_PASSWORD.
# Other providers: set SMTP_HOST/PORT accordingly (Outlook: smtp.office365.com:587)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@college.edu
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
SMTP_FROM_NAME=ClubHub

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173
# Base URL of the frontend — used in all email button links.
# Change this to your production domain when deploying.
FRONTEND_URL=http://localhost

# ── File Storage ──────────────────────────────────────────────────────────────
FILE_STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/app/media

# S3 (only needed when FILE_STORAGE_BACKEND=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=

# ── Postgres container env ────────────────────────────────────────────────────
POSTGRES_USER=ccops
POSTGRES_PASSWORD=ccops_pass
POSTGRES_DB=ccops

# ── RabbitMQ container env ────────────────────────────────────────────────────
RABBITMQ_DEFAULT_USER=ccops
RABBITMQ_DEFAULT_PASS=ccops_pass
